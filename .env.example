NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose or commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password
AI_KEY_ENCRYPTION_SECRET=use-a-separate-long-random-secret

# Used for provider headers and OAuth/deployment links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional provider model overrides.
CAREEROS_GEMINI_MODEL=gemini-3.5-flash
CAREEROS_GROQ_MODEL=openai/gpt-oss-20b
CAREEROS_OPENROUTER_MODEL=google/gemini-3.5-flash
